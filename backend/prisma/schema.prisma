generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model City {
  id       Int    @id @default(autoincrement())
  cityName String
}

model Location {
  id           Int                       @id @default(autoincrement())
  name         String
  description  String?
  address      String
  gMapLink     String?
  neighborhood String?
  latitude     Float
  longitude    Float
  locationType locationType?
  seatingLevel seatingLevel?
  quietLevel   Int?
  hasWifi      Boolean?                  @default(false)
  hasOutlets   Boolean?                  @default(false)
  tags         String[]                  @default([])
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([latitude, longitude])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
}

enum UserRole {
  USER
  ADMIN
}

enum locationType {
  CAFE
  LIBRARY
  SPACE
}

enum seatingLevel {
  LOW
  MEDIUM
  HIGH
}
